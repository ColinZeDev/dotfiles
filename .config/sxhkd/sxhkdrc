# Terminal
super + a
    kitty

# Browser
super + b
    flatpak run io.gitlab.librewolf-community

# VSCode
super + c
    code

# Music App (Cider)
super + m
    cider

# File manager
super + e
    thunar

# App Launcher
super + space
    rofi -show drun

# BTOP (task manager)
ctrl + shift + Escape
    kitty -e btop

# Lock screen
super + alt + l
    zsh $HOME/.config/bspwm/scripts/lock.zsh

# Exit bspwm prompt
super + Escape
    yad --title="Exit bspwm" \
        --text="Exit bspwm?" \
        --button="Yes:0" \
        --button="No:1" \
        --center \
        --on-top \
        --gtkrc "$HOME/.config/bspwm/misc/yad.css" \
        && bspc quit

# Shutdown Prompt
super + shift + Escape
    yad --title="Shutdown" \
        --text="Shutdown?" \
        --button="Yes:0" \
        --button="No:1" \
        --center \
        --on-top \
        --gtkrc "$HOME/.config/bspwm/misc/yad.css" \
        && shutdown now

# --- Window Management ---

super + f
    bspc node -t \~fullscreen

super + t
    bspc node -t \~floating

super + q
    bspc node -c

super + shift + q
    bspc node -k

super + {Left,Down,Up,Right}
    bspc node -f {west,south,north,east}

super + shift + {Left,Down,Up,Right}
    bspc node -s {west,south,north,east}

super + equal
    bspc node -z right +20 0 || bspc node -z left 0 -20
super + minus
    bspc node -z right -20 0 || bspc node -z left 0 +20

# --- Workspaces ---

super + {1-9}
    zsh $HOME/.config/bspwm/scripts/switch-workspace.zsh {1-9}

super + {Prior,Next}
    zsh $HOME/.config/bspwm/scripts/switch-workspace.zsh {prev,next}

super + shift + {1-9}
    bspc node -d '^{1-9}'

super + ctrl + shift + {1-9}
    bspc node -d '^{1-9}' --follow

super + ctrl + {Prior,Next}
    bspc node -d {prev,next}.local --follow

# --- Media ---

XF86AudioRaiseVolume
    zsh $HOME/.config/bspwm/scripts/volume.zsh up
XF86AudioLowerVolume
    zsh $HOME/.config/bspwm/scripts/volume.zsh down
shift + XF86AudioRaiseVolume
    zsh $HOME/.config/bspwm/scripts/volume.zsh up 1
shift + XF86AudioLowerVolume
    zsh $HOME/.config/bspwm/scripts/volume.zsh down 1
XF86AudioMute
    zsh $HOME/.config/bspwm/scripts/volume.zsh mute
XF86AudioMicMute
    zsh $HOME/.config/bspwm/scripts/volume.zsh mic

XF86MonBrightnessUp
    zsh $HOME/.config/bspwm/scripts/brightness.zsh up
XF86MonBrightnessDown
    zsh $HOME/.config/bspwm/scripts/brightness.zsh down
shift + XF86MonBrightnessUp
    zsh $HOME/.config/bspwm/scripts/brightness.zsh up 1
shift + XF86MonBrightnessDown
    zsh $HOME/.config/bspwm/scripts/brightness.zsh down 1h

# --- Misc ---

super + shift + s
    flameshot gui --clipboard --path $HOME/Pictures/Screenshots/BSPWM_$(date +%Y-%m-%d_%H%M%S_%a).png
super + ctrl + s
    flameshot full --path $HOME/Pictures/Screenshots/BSPWM_$(date +%Y-%m-%d_%H%M%S_%a).png
